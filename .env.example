# Supabase (https://supabase.com/dashboard → Project Settings → API)
# Copiez ce fichier en `.env.local` et renseignez les valeurs (Vite charge `.env.local`).
VITE_SUPABASE_URL=https://xxxx.supabase.co
# Ancienne appellation (JWT « anon ») :
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Nouvelle appellation (clé publishable, tableau de bord récent) — une des deux suffit :
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# remove.bg (https://www.remove.bg/api)
VITE_REMOVE_BG_API_KEY=

# EmailJS (https://www.emailjs.com/)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
# Adresse affichée / variable de modèle (selon votre template)
VITE_NOTIFY_EMAIL=vous@exemple.com

# Paiement — PayPal.me (montant ajouté automatiquement sur la page récap)
# Recommandé : URL de base (sans montant final), ex. https://paypal.me/votrepseudo
VITE_PAYPAL_ME_URL=
# Sinon : pseudo seul (défaut https://paypal.me/<pseudo>)
# VITE_PAYPAL_ME_USERNAME=yourusername

VITE_RECIPIENT_NAME=Nonore
# Optionnel : personnaliser les textes (voir src/constants.js)
# VITE_HERO_H1_LINE1=25 ANS : 2.5k reaux
# VITE_HERO_H1_LINE2_PREFIX=Pour l'iPad Pro 13" de 
# VITE_HERO_H2=Remplissons cette mosaïque...

# Optionnel : si `public/image_0.png` est absent, utilisez une URL ou un autre fichier public
# VITE_CASE_TEMPLATE_URL=/image_0.png
